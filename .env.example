# SQLite is the default. Omit DATABASE_URL to use DB_PATH.
DB_PATH=.alc.sqlite

# Optional Postgres backend.
# DATABASE_URL=postgres://user:password@localhost:5432/almost_living_context

# API server.
PORT=8787

# MCP server wrappers call the API.
SERVICE_URL=http://localhost:8787

# LLM provider: stub, ollama, openai, anthropic.
LLM_PROVIDER=stub
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_MODEL=claude-3-5-haiku-latest
